{
	"name": "create-etc-stack",
	"version": "0.4.0",
	"type": "module",
	"description": "Quickly scaffold new, opinionated project structures suitable for medium-sized applications, enforcing strong specifications and best practices from the start.",
	"license": "MIT",
	"author": "Etcetera",
	"keywords": [
		"cli",
		"template",
		"typescript",
		"biome",
		"monorepo",
		"electron",
		"shadcn"
	],
	"bin": {
		"create-etc-stack": "dist/index.mjs",
		"cva": "dist/index.mjs"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "tsdown --watch",
		"build": "bun run scripts/embed-templates.ts && tsdown",
		"build:compile": "bun run scripts/embed-templates.ts && bun build src/index.ts --compile --minify --bytecode --outfile create-etc-stack",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "bun run build",
		"publish-packages": "bun run build && changeset publish"
	},
	"engines": {
		"node": ">=20"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AmbitionsXXXV/create-etc-stack.git"
	},
	"homepage": "https://github.com/AmbitionsXXXV/create-etc-stack#readme",
	"devDependencies": {
		"@biomejs/biome": "2.4.7",
		"@changesets/cli": "^2.30.0",
		"@clack/prompts": "^1.1.0",
		"@types/cross-spawn": "^6.0.6",
		"@types/node": "^25.5.0",
		"cross-spawn": "^7.0.6",
		"mri": "^1.2.0",
		"picocolors": "^1.1.1",
		"tsdown": "^0.21.4"
	}
}
